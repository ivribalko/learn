{
  "name": "learn-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "VITE_BASE_PATH=/learn/ VITE_STATIC_PREVIEW=true npm run build",
    "preview": "vite preview --host 127.0.0.1",
    "preview:pages": "VITE_BASE_PATH=/learn/ vite preview --host 127.0.0.1",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "lucide-react": "1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "7.18.1",
    "vite": "8.1.3"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "6.0.3"
  }
}
